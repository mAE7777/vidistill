{
  "name": "vidistill",
  "version": "0.2.2",
  "description": "Video intelligence distiller — extract structured notes, transcripts, and insights from any video using Gemini",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "video",
    "ai",
    "gemini",
    "transcript",
    "notes",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "vidistill": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "1.0.1",
    "@google/genai": "^1.40.0",
    "citty": "^0.1.6",
    "figlet": "^1.8.0",
    "fluent-ffmpeg": "^2.1.3",
    "picocolors": "^1.1.1",
    "ytdlp-nodejs": "^2.2.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.4.0",
    "typescript": "^5.2.2",
    "vitest": "^3.2.4"
  }
}
