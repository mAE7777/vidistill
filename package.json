{
  "name": "vidistill",
  "version": "0.9.1",
  "description": "CLI and MCP server that turns long videos into transcripts, visual notes, reconstructed code, and structured markdown your AI editor can read",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.17.0",
  "author": "Sitao Ma",
  "homepage": "https://github.com/mAE7777/vidistill#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mAE7777/vidistill.git"
  },
  "bugs": {
    "url": "https://github.com/mAE7777/vidistill/issues"
  },
  "keywords": [
    "video",
    "ai",
    "gemini",
    "transcript",
    "transcription",
    "notes",
    "cli",
    "mcp",
    "model-context-protocol",
    "claude",
    "youtube",
    "yt-dlp",
    "obsidian",
    "video-analysis"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "vidistill": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "1.0.1",
    "@google/genai": "^1.52.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "citty": "^0.1.6",
    "figlet": "^1.11.0",
    "fluent-ffmpeg": "^2.1.3",
    "picocolors": "^1.1.1",
    "ytdlp-nodejs": "^2.3.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.19.20",
    "@vitest/coverage-v8": "^3.2.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
